{
  "name": "liftfuel",
  "version": "0.1.0",
  "private": true,
  "main": "expo/AppEntry",
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "build": "npm run backend:build && npx expo export --platform web",
    "backend:build": "tsc -p backend/tsconfig.build.json",
    "backend:dev": "tsx backend/src/server.ts",
    "backend:start": "node backend/dist/server.js",
    "backend:test": "node --import tsx --test backend/src/services/planEngine.test.ts backend/src/services/trainingSchedule.test.ts backend/src/routes/foodLog.test.ts backend/src/e2e/fullFlow.test.ts",
    "db:migrate": "tsx backend/src/db/migrate.ts",
    "typecheck": "tsc --noEmit && tsc -p backend/tsconfig.json --noEmit"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1091.0",
    "@react-navigation/bottom-tabs": "7.8.12",
    "@react-navigation/native": "7.3.12",
    "@react-navigation/native-stack": "7.18.4",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "expo": "57.0.7",
    "expo-image-picker": "~57.0.5",
    "expo-secure-store": "^57.0.1",
    "express": "^5.2.1",
    "jsonwebtoken": "^9.0.3",
    "jwks-rsa": "^4.1.0",
    "multer": "^2.2.0",
    "pg": "^8.22.0",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-native": "0.86.0",
    "react-native-gesture-handler": "~2.32.0",
    "react-native-safe-area-context": "~5.7.0",
    "react-native-screens": "4.25.2",
    "react-native-web": "0.21.2"
  },
  "devDependencies": {
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/multer": "^2.2.0",
    "@types/node": "^26.1.1",
    "@types/pg": "^8.20.0",
    "@types/react": "19.2.17",
    "tsx": "^4.23.1",
    "typescript": "~6.0.3"
  }
}
