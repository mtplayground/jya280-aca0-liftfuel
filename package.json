{
  "name": "liftfuel",
  "version": "0.1.0",
  "private": true,
  "main": "expo/AppEntry",
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "backend:build": "tsc -p backend/tsconfig.json",
    "backend:dev": "tsx backend/src/server.ts",
    "backend:start": "node backend/dist/server.js",
    "db:migrate": "tsx backend/src/db/migrate.ts",
    "typecheck": "tsc --noEmit && tsc -p backend/tsconfig.json --noEmit"
  },
  "dependencies": {
    "@react-navigation/bottom-tabs": "7.8.12",
    "@react-navigation/native": "7.3.12",
    "@react-navigation/native-stack": "7.18.4",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "expo": "57.0.7",
    "express": "^5.2.1",
    "pg": "^8.22.0",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-native": "0.86.0",
    "react-native-gesture-handler": "~2.32.0",
    "react-native-safe-area-context": "~5.7.0",
    "react-native-screens": "4.25.2",
    "react-native-web": "0.21.2"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^26.1.1",
    "@types/pg": "^8.20.0",
    "@types/react": "19.2.17",
    "tsx": "^4.23.1",
    "typescript": "~6.0.3"
  }
}
