NODE_ENV=development
HOST=0.0.0.0
PORT=8080
DATABASE_URL=postgres://user:password@host:5432/liftfuel
DATABASE_MAX_CONNECTIONS=5
API_BASE_PATH=/api
# Set both public URL values to the exact deployed website origin, for example:
# SELF_URL=https://jya280-aca0-liftfuel-6e5db6-bp4af.mctai.app
# ALLOWED_CORS_ORIGIN=https://jya280-aca0-liftfuel-6e5db6-bp4af.mctai.app
# For local development, use the origins below.
ALLOWED_CORS_ORIGIN=http://localhost:8081
SELF_URL=http://localhost:8080
# Optional frontend override. Leave unset in deployed web builds so requests use same-origin /api.
EXPO_PUBLIC_API_BASE_URL=http://localhost:8080/api
MCTAI_AUTH_URL=https://auth.mctai.app
MCTAI_AUTH_APP_TOKEN=app_jya280-aca0-liftfuel-6e5db6
MCTAI_AUTH_JWKS_URL=https://auth.mctai.app/.well-known/jwks.json
MCTAI_EMAIL_URL=
MCTAI_EMAIL_APP_TOKEN=
OBJECT_STORAGE_ENDPOINT=https://example-object-storage.local
OBJECT_STORAGE_REGION=auto
OBJECT_STORAGE_BUCKET=liftfuel
OBJECT_STORAGE_ACCESS_KEY_ID=
OBJECT_STORAGE_SECRET_ACCESS_KEY=
OBJECT_STORAGE_PREFIX=liftfuel/dev
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
