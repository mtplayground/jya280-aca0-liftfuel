NODE_ENV=development
HOST=0.0.0.0
PORT=8080
DATABASE_URL=postgres://user:password@host:5432/liftfuel
DATABASE_MAX_CONNECTIONS=5
API_BASE_PATH=/api
# Deployed web/API should share one public origin. Set both public URL values to
# the exact browser-visible website origin injected by the platform, for example:
# SELF_URL=https://jya280-aca0-liftfuel-6e5db6-bp4af.mctai.app
# ALLOWED_CORS_ORIGIN=https://jya280-aca0-liftfuel-6e5db6-bp4af.mctai.app
# For local development, use the origins below. Same-origin deployments should
# leave EXPO_PUBLIC_API_BASE_URL unset so web requests default to /api on the
# current origin and the mctai_session cookie is sent by normal same-origin rules.
ALLOWED_CORS_ORIGIN=http://localhost:8081
SELF_URL=http://localhost:8080
# Optional frontend override for local/native or explicitly split frontend/API
# hosts. Leave unset in deployed web builds that serve Expo and /api together.
EXPO_PUBLIC_API_BASE_URL=http://localhost:8080/api
MCTAI_AUTH_URL=https://auth.mctai.app
MCTAI_AUTH_APP_TOKEN=app_jya280-aca0-liftfuel-6e5db6
MCTAI_AUTH_JWKS_URL=https://auth.mctai.app/.well-known/jwks.json
# Optional cookie overrides. Usually leave blank: the server uses SameSite=Lax
# for same-origin requests and SameSite=None; Secure when a browser Origin is
# cross-site. Only set a domain when frontend/API share a parent domain and the
# auth service issues cookies for that same domain; never set localhost as a domain.
MCTAI_SESSION_COOKIE_DOMAIN=
MCTAI_SESSION_COOKIE_SAMESITE=
MCTAI_SESSION_COOKIE_SECURE=
MCTAI_EMAIL_URL=
MCTAI_EMAIL_APP_TOKEN=
OBJECT_STORAGE_ENDPOINT=https://example-object-storage.local
OBJECT_STORAGE_REGION=auto
OBJECT_STORAGE_BUCKET=liftfuel
OBJECT_STORAGE_ACCESS_KEY_ID=
OBJECT_STORAGE_SECRET_ACCESS_KEY=
OBJECT_STORAGE_PREFIX=liftfuel/dev
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
